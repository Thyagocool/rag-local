# ─── Configuração do RAG + Agentes + MCP ───────────────────────────────
# Copie este arquivo para .env e ajuste se necessário.
# Se o .env não existir, o sistema usa os valores padrão (localhost).

# ── Ollama (local) ─────────────────────────────────────────────────────
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_LLM_MODEL=llama3.2:3b
RAG_EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────
RAG_CHROMA_PERSIST_DIR=./data/chroma
RAG_COLLECTION_NAME=rag_docs

# ── App ────────────────────────────────────────────────────────────────
RAG_DEBUG=true

# ── Reranking ─────────────────────────────────────────────────────────
RAG_RERANKING_ENABLED=true

# ── Tracing / LLMOps (OpenTelemetry) ──────────────────────────────────
# Habilita tracing (requer opentelemetry instalado)
RAG_TRACING_ENABLED=false
# Endpoint OTLP para exportacao (ex: http://localhost:4318/v1/traces)
# Se vazio, usa console exporter (dev)
RAG_TRACING_OTLP_ENDPOINT=
