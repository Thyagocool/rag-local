# ─── Configuração do RAG + Agentes ───────────────────────────────────────────
# Copie este arquivo para .env e ajuste se necessário.
# Se o .env não existir, o sistema usa os valores padrão (localhost).

# Ollama (local)
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_LLM_MODEL=llama3.2:3b
RAG_EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
RAG_CHROMA_PERSIST_DIR=./data/chroma
RAG_COLLECTION_NAME=rag_docs

# App
RAG_DEBUG=true
